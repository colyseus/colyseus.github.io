---
import { Image } from 'astro:assets';

import Platforms from '../components/Platforms.astro';
import MainLayout from '../layouts/MainLayout.astro';
import ViewMore from '../components/ViewMore.astro';
import SponsorsSection from '../components/SponsorsSection.astro';
import CommunityStats from '../components/CommunityStats.astro';
import ScrollCodeShowcase from '../components/ScrollCodeShowcase.astro';

import scalabilityImage from "../../assets/diagrams/scalability.png";
import logoDiscordjs from "../../assets/framework/logo-discordjs.png";
import logoPlayfab from "../../assets/framework/logo-playfab.png";
import logoFirebase from "../../assets/framework/logo-firebase.png";
import logoMongodb from "../../assets/framework/logo-mongodb.png";
import logoPostgres from "../../assets/framework/logo-postgres.png";

---

<MainLayout title="The Multiplayer Framework Developers Love" description="Open-source real-time multiplayer framework for Node.js. Built-in matchmaking, automatic state synchronization, scalability, and client SDKs for Unity, Defold, Haxe, and JavaScript." isHeaderExpanded={false} isBlue={false}>
  <section id="hero" class="text-gray-200 min-h-[99vh] flex bg-section-glow-purple overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 py-10 flex items-center min-w-0">
      <div class="flex justify-between flex-col lg:flex-row space-x-0 lg:space-x-8 w-full min-w-0">

        <!-- Left -->
        <div class="w-full min-w-0">
          <div class="pt-20 pb-4 animate-fade-up">
            <svg class="w-16 text-purple-500" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 122 133.24"> <defs> <style> .herocf1 { fill: url(#linear-gradient-2); } .herocf2 { fill: #000; } .herocf3 { fill: url(#linear-gradient-3); } .herocf4 { fill: url(#linear-gradient); } </style> <linearGradient id="linear-gradient" x1="13.09" y1="4.21" x2="132.62" y2="99.02" gradientUnits="userSpaceOnUse"> <stop offset="0" stop-color="#a32fe0"/> <stop offset="1" stop-color="#5945e3"/> </linearGradient> <linearGradient id="linear-gradient-2" x1="16.8" y1="-.46" x2="136.33" y2="94.34" xlink:href="#linear-gradient"/> <linearGradient id="linear-gradient-3" x1="-14.54" y1="39.05" x2="104.99" y2="133.85" xlink:href="#linear-gradient"/> </defs> <g> <g> <path class="herocf4" d="m19.8,48.53c3.4,2.77,7.52,5.48,12.5,7.91,3.66-7.06,17.75-24.8,57.44-19.62l-3.55-13.63c-49.3-4.23-63.47,18.99-66.4,25.34Z"/> <path class="herocf1" d="m10.96,41.3c5.52-10.03,24.41-30.58,71.44-26.05L76.37.39S27.06-5.33,2.19,26.95c.89,2.6,3.28,8.21,8.77,14.35Z"/> <path class="herocf3" d="m100.37,71.71c-7.91.83-15.27,1.22-22.07,1.22C30.31,72.92,9.06,54.07,0,40.61v62.04s3.88,40.13,120.38,28.48l-20-59.42Z"/> </g> </g> </svg>
            <h1 class="font-display text-5xl mt-8 text-semibold gradient-text">The Multiplayer Framework Developers Love</h1>
            <p class="mt-4 text-xl text-slate-300">Open-source, battle-tested, and built for real-time games. Free forever.</p>
          </div>
          <div class="flex space-x-6 my-8 items-center animate-fade-up flex-col lg:flex-row max-w-full overflow-hidden">

            <span class="flex lg:block bg-gradient-purple p-1 rounded mx-auto lg:mx-0 w-full md:w-auto lg:w-auto text-sm lg:text-base max-w-full overflow-hidden">
              <span class="font-mono bg-gray-950 pl-1 lg:pl-5 rounded relative flex items-center justify-start lg:justify-center overflow-hidden min-w-0">
                <!-- caret -->
                <svg class="inline-block relative w-3 -rotate-90 text-gray-300 mr-2" stroke="currentColor" data-hk="0-0" width="22" height="13" viewBox="0 0 22 13" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1L11 11L21 1" stroke-width="2"></path></svg>
                <span class="text-gray-300 whitespace-nowrap text-ellipsis lg:w-full overflow-hidden">npm create colyseus-app@latest ./my-server</span>
                <button class="group inline-block cursor-pointer p-3 lg:p-5 relative flex-shrink-0" id="clipboard-click">
                  <svg class="inline-block w-5 text-gray-400 transition-all group-hover:scale-125 group-active:scale-75 group-active:text-purple-300  group-hover:text-gray-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"> <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect> <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                  <span
                    class="absolute pointer-events-none hidden bg-black data-[clicked=yes]:inline-block text-purple-200 text-sm bg-purple-600 rounded py-2 px-3 -translate-x-12 translate-y-10"
                    data-clicked="no"
                  >
                    Copied!
                  </span>
                </button>

                <script is:inline>
                  const button = document.getElementById('clipboard-click');
                  const icon = button.querySelector('span');
                  let timeout = null;
                  button.addEventListener('click', () => {
                    navigator.clipboard.writeText('npm create colyseus-app@latest ./my-server');
                    clearTimeout(timeout);
                    icon.dataset.clicked = 'yes';
                    timeout = setTimeout(() => icon.dataset.clicked = 'no', 1000);
                  });
                </script>
              </span>
            </span>

            <!--a
              class="hidden lg:hidden lg:block m-auto text-lg text-center rounded-full bg-purple-600 text-white font-semibold py-4 px-8 mr-4 transition-all hover:bg-purple-700 active:bg-purple-800 hover:shadow-inner"
              target="_blank"
              href="https://stackblitz.com/edit/colyseus?embed=1&file=src%2Frooms%2FMyRoom.ts"
            >
              See in action ⚡️
            </a-->

          </div>

          <div class="flex flex-col py-8 text-gray-400">
            <Platforms align="left" />
          </div>

        </div>

        <!-- Right -->
        <div class="justify-center items-center text-lg flex grow">
          <ul class="space-y-4 text-xl self-center rounded-lg lg:whitespace-nowrap p-8 bg-black/40 flex flex-col">

            <li class="animate-fade-up animate-delay-005">
              <svg class="inline mr-1 text-green-600" height="1em" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 512 512"><path d="M256 0c4.6 0 9.2 1 13.4 2.9L457.7 82.8c22 9.3 38.4 31 38.3 57.2c-.5 99.2-41.3 280.7-213.6 363.2c-16.7 8-36.1 8-52.8 0C57.3 420.7 16.5 239.2 16 140c-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.8 1 251.4 0 256 0z"/></svg>
              <span>Cheat-proof by design</span>
            </li>

            <li class="animate-fade-up animate-delay-010">
              <svg class="inline mr-1 text-green-600" height="1em" viewBox="0 0 576 512" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M320 32c0-9.9-4.5-19.2-12.3-25.2S289.8-1.4 280.2 1l-179.9 45C79 51.3 64 70.5 64 92.5V448H32c-17.7 0-32 14.3-32 32s14.3 32 32 32H96 288h32V480 32zM256 256c0 17.7-10.7 32-24 32s-24-14.3-24-32s10.7-32 24-32s24 14.3 24 32zm96-128h96V480c0 17.7 14.3 32 32 32h64c17.7 0 32-14.3 32-32s-14.3-32-32-32H512V128c0-35.3-28.7-64-64-64H352v64z"/></svg>
              <a href="#match-making">Built-in matchmaking</a>
            </li>

            <li class="animate-fade-up animate-delay-015">
              <svg class="inline mr-1 text-green-600" fill="currentColor" height="1em" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M142.9 142.9c62.2-62.2 162.7-62.5 225.3-1L327 183c-6.9 6.9-8.9 17.2-5.2 26.2s12.5 14.8 22.2 14.8H463.5c0 0 0 0 0 0H472c13.3 0 24-10.7 24-24V72c0-9.7-5.8-18.5-14.8-22.2s-19.3-1.7-26.2 5.2L413.4 96.6c-87.6-86.5-228.7-86.2-315.8 1C73.2 122 55.6 150.7 44.8 181.4c-5.9 16.7 2.9 34.9 19.5 40.8s34.9-2.9 40.8-19.5c7.7-21.8 20.2-42.3 37.8-59.8zM16 312v7.6 .7V440c0 9.7 5.8 18.5 14.8 22.2s19.3 1.7 26.2-5.2l41.6-41.6c87.6 86.5 228.7 86.2 315.8-1c24.4-24.4 42.1-53.1 52.9-83.7c5.9-16.7-2.9-34.9-19.5-40.8s-34.9 2.9-40.8 19.5c-7.7 21.8-20.2 42.3-37.8 59.8c-62.2 62.2-162.7 62.5-225.3 1L185 329c6.9-6.9 8.9-17.2 5.2-26.2s-12.5-14.8-22.2-14.8H48.4h-.7H40c-13.3 0-24 10.7-24 24z"/></svg>
              <a href="#state-sync">Real-time sync that just works</a>
            </li>

            <li class="animate-fade-up animate-delay-020">
              <svg class="inline mr-1 text-green-600" height="1em" fill="currentColor" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512"><path d="M0 80C0 53.5 21.5 32 48 32h96c26.5 0 48 21.5 48 48V96H384V80c0-26.5 21.5-48 48-48h96c26.5 0 48 21.5 48 48v96c0 26.5-21.5 48-48 48H432c-26.5 0-48-21.5-48-48V160H192v16c0 1.7-.1 3.4-.3 5L272 288h96c26.5 0 48 21.5 48 48v96c0 26.5-21.5 48-48 48H272c-26.5 0-48-21.5-48-48V336c0-1.7 .1-3.4 .3-5L144 224H48c-26.5 0-48-21.5-48-48V80z"/></svg>
              <span>Scale from 10 to 10,000+ CCU</span>
            </li>

            <li class="animate-fade-up animate-delay-025">
              <svg class="inline mr-1 text-green-600" fill="currentColor" xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 512 512"><path d="M177.9 494.1c-18.7 18.7-49.1 18.7-67.9 0L17.9 401.9c-18.7-18.7-18.7-49.1 0-67.9l50.7-50.7 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 41.4-41.4 48 48c6.2 6.2 16.4 6.2 22.6 0s6.2-16.4 0-22.6l-48-48 50.7-50.7c18.7-18.7 49.1-18.7 67.9 0l92.1 92.1c18.7 18.7 18.7 49.1 0 67.9L177.9 494.1z"/></svg>
              <a href="#scalability">Self-host or use Colyseus Cloud</a>
            </li>

            <li class="animate-fade-up animate-delay-030">
              <svg class="inline mr-1 text-green-600" height="1em" stroke="currentColor" fill="currentColor" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><path d="M0 32v448h448V32H0zm243.8 349.4c0 43.6-25.6 63.5-62.9 63.5-33.7 0-53.2-17.4-63.2-38.5l34.3-20.7c6.6 11.7 12.6 21.6 27.1 21.6 13.8 0 22.6-5.4 22.6-26.5V237.7h42.1v143.7zm99.6 63.5c-39.1 0-64.4-18.6-76.7-43l34.3-19.8c9 14.7 20.8 25.6 41.5 25.6 17.4 0 28.6-8.7 28.6-20.8 0-14.4-11.4-19.5-30.7-28l-10.5-4.5c-30.4-12.9-50.5-29.2-50.5-63.5 0-31.6 24.1-55.6 61.6-55.6 26.8 0 46 9.3 59.8 33.7L368 290c-7.2-12.9-15-18-27.1-18-12.3 0-20.1 7.8-20.1 18 0 12.6 7.8 17.7 25.9 25.6l10.5 4.5c35.8 15.3 55.9 31 55.9 66.2 0 37.8-29.8 58.6-69.7 58.6z"></path></svg>
              <a href="#ecosystem">Use tools you already know</a>
            </li>

            <li class="animate-fade-up animate-delay-035">
              <svg class="inline mr-1 text-green-600" fill="currentColor" height="1em" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><g><path id="path2996" d="m16 0.4c-8.8 0-16 7.2-16 16 0 7 4.4 12.9 10.6 15.1l4-10.4c-2-0.7-3.5-2.5-3.5-4.7 0-2.7 2.2-4.8 4.9-4.8 2.7 0 4.9 2.1 4.9 4.8 0 2.2-1.5 4.1-3.5 4.7l4 10.4c6.2-2.2 10.6-8.1 10.6-15.1 0-8.8-7.2-16-16-16z"/></g></svg>
              <a href="https://github.com/colyseus/colyseus">Free forever (MIT License)</a>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <ScrollCodeShowcase />

  <section class="border-b border-white/5 bg-section-glow-blue">
    <div class="max-w-7xl mx-auto px-6 relative py-24">

      <div class="text-center mb-8">
        <p class="text-sm font-medium text-purple-400 uppercase tracking-widest mb-4">Under the Hood</p>
        <h2 class="text-2xl lg:text-4xl font-bold text-white mb-4">Architecture / Stack</h2>
        <p class="text-gray-400 max-w-xl mx-auto">A solid stack so you can focus on your game instead of re-inventing the wheel.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <a href="https://nodejs.org/en/about" target="_blank" class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-400" fill="currentColor" viewBox="0 0 448 512"><path d="M224.5 508c-6.7 0-13.5-1.8-19.4-5.2l-61.7-36.5c-9.2-5.2-4.7-7-1.7-8 12.3-4.3 14.8-5.2 27.9-12.7 1.4-.8 3.2-.5 4.6 .4l47.4 28.1c1.7 1 4.1 1 5.7 0L412 367.5c1.7-1 2.8-3 2.8-5l0-213.2c0-2.1-1.1-4-2.9-5.1L227.3 37.7c-1.7-1-4-1-5.7 0L37.1 144.3c-1.8 1-2.9 3-2.9 5.1l0 213.1c0 2 1.1 4 2.9 4.9l50.6 29.2c27.5 13.7 44.3-2.4 44.3-18.7l0-210.4c0-3 2.4-5.3 5.4-5.3l23.4 0c2.9 0 5.4 2.3 5.4 5.3l0 210.5c0 36.6-20 57.6-54.7 57.6-10.7 0-19.1 0-42.5-11.6L20.6 396.1c-12-6.9-19.4-19.8-19.4-33.7l0-213.1c0-13.8 7.4-26.8 19.4-33.7L205.1 9c11.7-6.6 27.2-6.6 38.8 0L428.6 115.7c12 6.9 19.4 19.8 19.4 33.7l0 213.1c0 13.8-7.4 26.7-19.4 33.7L243.9 502.8c-5.9 3.4-12.6 5.2-19.4 5.2zM373.6 297.9c0-39.9-27-50.5-83.7-58-57.4-7.6-63.2-11.5-63.2-24.9 0-11.1 4.9-25.9 47.4-25.9 37.9 0 51.9 8.2 57.7 33.8 .5 2.4 2.7 4.2 5.2 4.2l24 0c1.5 0 2.9-.6 3.9-1.7s1.5-2.6 1.4-4.1c-3.7-44.1-33-64.6-92.2-64.6-52.7 0-84.1 22.2-84.1 59.5 0 40.4 31.3 51.6 81.8 56.6 60.5 5.9 65.2 14.8 65.2 26.7 0 20.6-16.6 29.4-55.5 29.4-48.9 0-59.6-12.3-63.2-36.6-.4-2.6-2.6-4.5-5.3-4.5l-23.9 0c-3 0-5.3 2.4-5.3 5.3 0 31.1 16.9 68.2 97.8 68.2 58.4-.1 92-23.2 92-63.4z"/></svg>
            </div>
            <svg class="w-4 h-4 text-gray-600 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Node.js Runtime</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Asynchronous event-driven JavaScript runtime, designed to build scalable network applications.</p>
        </a>

        <a href="https://docs.colyseus.io/server/transport/" target="_blank" class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <svg class="w-4 h-4 text-gray-600 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Networking Transport</h3>
          <p class="text-sm text-gray-500 leading-relaxed">WebSockets as transport layer, with WebTransport support in our public roadmap.</p>
        </a>

        <a href="https://docs.colyseus.io/server/room/" target="_blank" class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <svg class="w-4 h-4 text-gray-600 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Room-Based System</h3>
          <p class="text-sm text-gray-500 leading-relaxed">On-demand, stateful rooms are spawned per client request.</p>
        </a>

        <a href="https://docs.colyseus.io/state/" target="_blank" class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <svg class="w-4 h-4 text-gray-600 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Message Serialization</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Binary delta serialization for state sync, and the fastest MessagePack serializer for everything else.</p>
        </a>

        <a href="https://docs.colyseus.io/server/custom-http-routes/" target="_blank" class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <svg class="w-4 h-4 text-gray-600 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Web / API Routes</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Define your own custom API routes via Express or better-call.</p>
        </a>

        <div class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Database / Auth</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Bring your favorite Node.js tools. You choose which database or authentication provider to use.</p>
        </div>
      </div>

      <div class="text-center mt-8">
        <ViewMore href="https://docs.colyseus.io/learn">Learn Colyseus</ViewMore>
      </div>

    </div>
  </section>

  <section id="scalability" class="border-b border-white/5 bg-gray-800">
    <div class="max-w-7xl mx-auto px-6 relative py-24 text-center mb-8">
