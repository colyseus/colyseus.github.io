      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-6xl mx-auto">
        {[
          { title: "vs Photon", items: ["Open-source, own your servers", "No CCU pricing surprises", "Full server-side control"] },
          { title: "vs Mirror", items: ["Works with any game engine", "Not tied to Unity", "Dedicated server architecture"] },
          { title: "vs Nakama", items: ["Simpler API, faster to learn", "TypeScript-native", "Focused on real-time games"] },
          { title: "vs From Scratch", items: ["Battle-tested in production", "Ship in days, not months", "Active community support"] },
