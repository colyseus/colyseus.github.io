  <section class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-32">
      <div class="text-center mb-12">
        <p class="text-sm font-medium text-purple-400 uppercase tracking-widest mb-4">Showcase</p>
        <h2 class="text-2xl lg:text-4xl font-bold text-white mb-4">Games Using Colyseus</h2>
        <p class="text-gray-500">A selection of multiplayer games made by happy developers.</p>
      </div>

      <div id="showcase" class="h-[28rem] lg:h-[32rem] transition-all overflow-hidden relative">
        <div class="grid gap-3 lg:gap-4 showcase-items grid-cols-2 lg:grid-cols-3">
          {collections.showcase.map((item) => (
            <a
              class="group rounded-xl h-28 lg:h-60 relative transition-all overflow-hidden border border-white/5 hover:border-white/10"
              href={item.url}
              target="_blank"
              style={`background-image: url(${item.image});`}
            >
              <span class="bg-black/80 backdrop-blur-sm translate-y-full group-hover:translate-y-0 transition-transform absolute bottom-0 p-3 lg:p-4 w-full text-white">
                <span class="text-xs lg:text-sm font-medium">{item.name}</span>
                <small class="block text-gray-400 text-xs">by {item.author}</small>
                <img class="absolute right-3 bottom-3 w-5 lg:w-8 opacity-60" src={platforms[item.platform].image} alt={platforms[item.platform].name} />
              </span>
            </a>
          ))}
        </div>

        <a
          href="javascript:void(0)" onclick="document.getElementById('showcase').classList.remove('h-[28rem]','lg:h-[32rem]');this.remove();"
          class="showcase-expand-list pt-10 flex h-28 justify-center items-end w-full absolute bottom-0 group text-gray-500 hover:text-gray-300 font-medium text-sm transition-colors"
        >
          Show all games
          <svg class="inline-block ml-2 transition-transform group-hover:translate-x-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

