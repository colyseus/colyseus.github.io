---
import MainLayout from '../layouts/MainLayout.astro';

import { collections } from '../content/config';

import ColyseusCloudSection from '../components/ColyseusCloudSection.astro';
import SponsorsSection from '../components/SponsorsSection.astro';
import SuccessStoriesSection from '../components/SuccessStoriesSection.astro';
import JoinCommunitySection from '../components/JoinCommunitySection.astro';
import Platforms, { platforms } from '../components/Platforms.astro';

const subtitle = "The developer-friendly framework for real-time multiplayer. From prototype to production in days, not months.";
---

<MainLayout title="Ship Multiplayer Games Faster" description={subtitle} isHeaderExpanded={false}>

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[90vh] lg:min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 bg-gradient-radial-hero"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-purple-500/5 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-6 text-center relative z-10 py-32 lg:py-40">
      <h1 class="font-display text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight text-white mb-6 animate-fade-up">
        Ship Multiplayer Games
        <br />
        <span class="gradient-text">Faster</span>
      </h1>

      <p class="text-base lg:text-xl text-gray-400 max-w-2xl mx-auto mb-10 animate-fade-up animate-delay-1">
        {subtitle}
      </p>

      <!-- Terminal Command -->
      <div class="animate-fade-up animate-delay-2 max-w-xl mx-auto mb-8">
        <div class="bg-white/[0.03] border border-white/10 rounded-xl p-1">
          <div class="flex items-center bg-white/[0.02] rounded-lg px-4 py-3">
            <span class="text-gray-600 mr-3 select-none">$</span>
            <code class="font-mono text-sm lg:text-base text-gray-300 flex-1 text-left">npm create colyseus-app@latest ./my-server</code>
            <button class="group p-2 rounded-lg hover:bg-white/5 transition-colors" id="clipboard-click">
              <svg class="w-4 h-4 text-gray-500 group-hover:text-gray-300 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <span
                class="absolute pointer-events-none hidden data-[clicked=yes]:inline-block text-xs bg-white/10 text-white rounded py-1 px-2 -translate-x-8 translate-y-6"
                data-clicked="no"
              >
                Copied!
              </span>
            </button>
          </div>
        </div>
        <p class="text-xs text-gray-600 mt-3">
          <a href="https://nodejs.org/en" target="_blank" class="hover:text-gray-400 transition-colors">Requires Node.js</a>
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 justify-center animate-fade-up animate-delay-3">
        <a href="https://docs.colyseus.io/" class="px-6 py-3 rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-medium text-sm transition-colors">
          Get Started
        </a>
        <a href="https://github.com/colyseus/colyseus" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-white/10 hover:border-white/20 hover:bg-white/5 text-white font-medium text-sm transition-all">
          <svg fill="currentColor" width="16" height="16" viewBox="0 0 496 512"><path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3.7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9 1.6 1 3.6.7 4.3-.7.7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3.7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3.7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z"/></svg>
          View on GitHub
        </a>
      </div>
    </div>

    <script is:inline>
      const button = document.getElementById('clipboard-click');
      if (button) {
        const icon = button.querySelector('span');
        let timeout = null;
        button.addEventListener('click', () => {
          navigator.clipboard.writeText('npm create colyseus-app@latest ./my-server');
          clearTimeout(timeout);
          icon.dataset.clicked = 'yes';
          timeout = setTimeout(() => icon.dataset.clicked = 'no', 1000);
        });
      }
    </script>
  </section>

  <!-- ===== SOCIAL PROOF BAR ===== -->
  <section class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 py-10">
      <p class="text-center text-xs uppercase tracking-widest text-gray-600 mb-8">Trusted by games with millions of players</p>
      <div class="flex flex-wrap justify-center items-center gap-6 lg:gap-12">
        <a href="https://pixels.xyz/" target="_blank" class="opacity-50 hover:opacity-80 transition-opacity">
          <img src="/images/showcase/pixels.jpeg" alt="Pixels.xyz" class="h-10 lg:h-14 rounded-lg" />
        </a>
        <a href="https://bloxd.io/" target="_blank" class="opacity-50 hover:opacity-80 transition-opacity">
          <img src="/images/showcase/bloxdio.jpeg" alt="Bloxd.io" class="h-10 lg:h-14 rounded-lg" />
        </a>
        <a href="https://kirka.io/" target="_blank" class="opacity-50 hover:opacity-80 transition-opacity">
          <img src="/images/showcase/kirka-io.jpeg" alt="Kirka.io" class="h-10 lg:h-14 rounded-lg" />
        </a>
        <a href="https://makeitmeme.com/" target="_blank" class="opacity-50 hover:opacity-80 transition-opacity">
          <img src="/images/showcase/makeitmeme.webp" alt="Make it Meme" class="h-10 lg:h-14 rounded-lg" />
        </a>
        <a href="https://swordmasters.io/" target="_blank" class="opacity-50 hover:opacity-80 transition-opacity">
          <img src="/images/showcase/swordmasters.png" alt="Sword Masters" class="h-10 lg:h-14 rounded-lg" />
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CODE EXAMPLE ===== -->
  <section class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-32">
      <div class="text-center mb-16">
        <p class="text-sm font-medium text-purple-400 uppercase tracking-widest mb-4">See It In Action</p>
        <h2 class="text-2xl lg:text-4xl font-bold text-white mb-4">Real-Time State Sync in Minutes</h2>
        <p class="text-gray-400 max-w-xl mx-auto">Define your game state on the server. Colyseus syncs it to all clients automatically — no manual serialization needed.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6 max-w-5xl mx-auto">
        <!-- Server Code -->
        <div class="rounded-xl border border-white/5 overflow-hidden bg-white/[0.02]">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-white/[0.02]">
            <div class="flex gap-1.5">
              <span class="w-3 h-3 rounded-full bg-white/10"></span>
              <span class="w-3 h-3 rounded-full bg-white/10"></span>
              <span class="w-3 h-3 rounded-full bg-white/10"></span>
            </div>
            <span class="text-xs text-gray-500 ml-2 font-mono">GameRoom.ts</span>
            <span class="ml-auto text-[10px] uppercase tracking-wider text-gray-600 font-medium">Server</span>
          </div>
          <pre class="p-4 lg:p-6 text-sm leading-relaxed overflow-x-auto"><code><span class="syn-keyword">import</span> {'{'} Room, Client {'}'} <span class="syn-keyword">from</span> <span class="syn-string">"colyseus"</span>;
<span class="syn-keyword">import</span> {'{'} GameState, Player {'}'} <span class="syn-keyword">from</span> <span class="syn-string">"./GameState"</span>;

<span class="syn-keyword">export class</span> <span class="syn-type">GameRoom</span> <span class="syn-keyword">extends</span> <span class="syn-type">Room</span>&lt;<span class="syn-type">GameState</span>&gt; {'{'}

  <span class="syn-function">onCreate</span>() {'{'}
    <span class="syn-keyword">this</span>.<span class="syn-function">setState</span>(<span class="syn-keyword">new</span> <span class="syn-type">GameState</span>());

    <span class="syn-keyword">this</span>.<span class="syn-function">onMessage</span>(<span class="syn-string">"move"</span>, (client, data) =&gt; {'{'}
      <span class="syn-keyword">const</span> player = <span class="syn-keyword">this</span>.state.players.<span class="syn-function">get</span>(client.sessionId);
      player.x += data.x;
      player.y += data.y;
    {'}'});
  {'}'}

  <span class="syn-function">onJoin</span>(client: <span class="syn-type">Client</span>) {'{'}
    <span class="syn-keyword">this</span>.state.players.<span class="syn-function">set</span>(client.sessionId, <span class="syn-keyword">new</span> <span class="syn-type">Player</span>());
  {'}'}

  <span class="syn-function">onLeave</span>(client: <span class="syn-type">Client</span>) {'{'}
    <span class="syn-keyword">this</span>.state.players.<span class="syn-function">delete</span>(client.sessionId);
  {'}'}
{'}'}</code></pre>
        </div>

        <!-- Client Code -->
        <div class="rounded-xl border border-white/5 overflow-hidden bg-white/[0.02]">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-white/[0.02]">
            <div class="flex gap-1.5">
              <span class="w-3 h-3 rounded-full bg-white/10"></span>
              <span class="w-3 h-3 rounded-full bg-white/10"></span>
              <span class="w-3 h-3 rounded-full bg-white/10"></span>
            </div>
            <span class="text-xs text-gray-500 ml-2 font-mono">game.ts</span>
            <span class="ml-auto text-[10px] uppercase tracking-wider text-gray-600 font-medium">Client</span>
          </div>
          <pre class="p-4 lg:p-6 text-sm leading-relaxed overflow-x-auto"><code><span class="syn-keyword">import</span> {'{'} Client {'}'} <span class="syn-keyword">from</span> <span class="syn-string">"colyseus.js"</span>;

<span class="syn-keyword">const</span> client = <span class="syn-keyword">new</span> <span class="syn-type">Client</span>(<span class="syn-string">"wss://your-server.colyseus.cloud"</span>);
<span class="syn-keyword">const</span> room = <span class="syn-keyword">await</span> client.<span class="syn-function">joinOrCreate</span>(<span class="syn-string">"game_room"</span>);

<span class="syn-comment">// Listen to state changes in real-time</span>
room.state.players.<span class="syn-function">onAdd</span>((player, key) =&gt; {'{'}

  player.<span class="syn-function">onChange</span>(() =&gt; {'{'}
    <span class="syn-comment">// Automatically called when state changes</span>
    <span class="syn-function">updateSprite</span>(key, player.x, player.y);
  {'}'});

{'}'});

<span class="syn-comment">// Send actions to the server</span>
room.<span class="syn-function">send</span>(<span class="syn-string">"move"</span>, {'{'} x: <span class="syn-number">1</span>, y: <span class="syn-number">0</span> {'}'});</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURES GRID ===== -->
  <section class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-32">
      <div class="text-center mb-16">
        <p class="text-sm font-medium text-purple-400 uppercase tracking-widest mb-4">Why Colyseus</p>
        <h2 class="text-2xl lg:text-4xl font-bold text-white">Everything You Need for Multiplayer</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- Feature 1 -->
        <div class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Real-Time State Sync</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Automatic binary state synchronization. Define your state once, sync everywhere.</p>
        </div>

        <!-- Feature 2 -->
        <div class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Built-in Matchmaking</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Automatic room creation and player matching. Customizable filtering and sorting.</p>
        </div>

        <!-- Feature 3 -->
        <div class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Scalable Architecture</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Scale from 10 to 10,000+ CCU. Distribute rooms across multiple processes or machines.</p>
        </div>

        <!-- Feature 4 -->
        <div class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Cheat-Proof by Design</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Authoritative server architecture. Game state lives on the server, not the client.</p>
        </div>

        <!-- Feature 5 -->
        <div class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 10h16M4 14h16M4 18h16" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Multi-Platform SDKs</h3>
          <p class="text-sm text-gray-500 leading-relaxed">JavaScript, Unity, Defold, Construct 3, Haxe, and Cocos Creator. Use the tools you already know.</p>
        </div>

        <!-- Feature 6 -->
        <div class="group p-6 rounded-xl border border-white/5 hover:border-white/10 bg-white/[0.02] hover:bg-white/[0.04] transition-all">
          <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Free & Open Source</h3>
          <p class="text-sm text-gray-500 leading-relaxed">MIT licensed. Free forever, even for commercial games. Full control over your infrastructure.</p>
        </div>
      </div>

      <!-- Platform icons -->
      <div class="mt-16 flex justify-center">
        <Platforms />
      </div>
    </div>
  </section>

  <!-- ===== TWO PRODUCTS ===== -->
  <section class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-32">
      <div class="text-center mb-16">
        <p class="text-sm font-medium text-purple-400 uppercase tracking-widest mb-4">Get Started</p>
        <h2 class="text-2xl lg:text-4xl font-bold text-white mb-4">Two Ways to Build</h2>
        <p class="text-gray-400 max-w-xl mx-auto">Colyseus Framework is free and open-source. Colyseus Cloud is the easiest way to deploy it.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <!-- Framework Card -->
        <div class="group rounded-xl border border-purple-500/20 bg-purple-500/[0.03] p-8 hover:border-purple-500/30 transition-all">
          <div class="flex items-center gap-3 mb-4">
            <svg class="w-8 h-8" version="1.2" viewBox="0 0 120 134"> <defs> <linearGradient id="hcfg1" x2="1" gradientUnits="userSpaceOnUse" gradientTransform="matrix(119.53,94.81,-119.798,151.033,13.09,4.21)"> <stop offset="0" stop-color="#a32fe0"/> <stop offset="1" stop-color="#5945e3"/> </linearGradient> <linearGradient id="hcfg2" x2="1" gradientUnits="userSpaceOnUse" gradientTransform="matrix(119.53,94.8,-124.011,156.362,16.8,-0.46)"> <stop offset="0" stop-color="#a32fe0"/> <stop offset="1" stop-color="#5945e3"/> </linearGradient> <linearGradient id="hcfg3" x2="1" gradientUnits="userSpaceOnUse" gradientTransform="matrix(119.53,94.8,-57.693,72.743,-14.54,39.05)"> <stop offset="0" stop-color="#a32fe0"/> <stop offset="1" stop-color="#5945e3"/> </linearGradient> </defs> <g> <g> <path fill="url(#hcfg1)" d="m19.8 48.5c3.4 2.8 7.5 5.5 12.5 7.9 3.7-7 17.7-24.8 57.4-19.6l-3.5-13.6c-49.3-4.2-63.5 19-66.4 25.3z"/> <path fill="url(#hcfg2)" d="m11 41.3c5.5-10 24.4-30.6 71.4-26.1l-6-14.8c0 0-49.3-5.7-74.2 26.6 0.9 2.6 3.3 8.2 8.8 14.3z"/> <path fill="url(#hcfg3)" d="m100.4 71.7q-11.9 1.2-22.1 1.2c-48 0-69.2-18.8-78.3-32.3v62c0 0.1 3.9 40.2 120.4 28.5 0 0-20-59.4-20-59.4z"/> </g> </g> </svg>
            <h3 class="text-xl font-semibold text-white">Colyseus Framework</h3>
          </div>
          <p class="text-gray-400 text-sm mb-6">The open-source multiplayer engine. Build with JavaScript/TypeScript. Self-host anywhere.</p>
          <ul class="space-y-3 text-sm text-gray-400 mb-8">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-purple-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Free and open-source (MIT)
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-purple-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Full control over your servers
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-purple-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Deploy anywhere you want
            </li>
          </ul>
          <a href="/framework" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors">
            Explore the Framework
