---
import {
  npmDownloadCount,
  githubStars,
  allContributors,
  discordMemberCount,
} from "../indexes/stats";
---
<div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 py-8">

  <div class="text-center">
    <span class="block text-3xl lg:text-4xl font-bold text-white">{Math.floor(npmDownloadCount/1000)}K+</span>
    <span class="block text-sm text-gray-500 mt-1">Downloads</span>
  </div>

  <div class="text-center">
    <span class="block text-3xl lg:text-4xl font-bold text-white">{(githubStars/1000).toFixed(1)}K</span>
    <span class="block text-sm text-gray-500 mt-1">GitHub Stars</span>
  </div>

  <div class="text-center">
    <span class="block text-3xl lg:text-4xl font-bold text-white">{allContributors.length}</span>
    <span class="block text-sm text-gray-500 mt-1">Contributors</span>
  </div>

  <div class="text-center">
    <span class="block text-3xl lg:text-4xl font-bold text-white">{(discordMemberCount/1000).toFixed(1)}K</span>
    <span class="block text-sm text-gray-500 mt-1">Discord Members</span>
  </div>

</div>
