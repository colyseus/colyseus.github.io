---
import { sdks } from "../data/sdks";
import SDKClientCode from "./SDKClientCode.astro";
import SDKLinks from "./SDKLinks.astro";
---

<section id="client-sdks" class="border-b border-white/5 bg-section-glow-purple">
  <div class="max-w-7xl mx-auto px-6 py-24">

    <div class="text-center mb-12">
      <p class="text-sm font-medium text-purple-400 uppercase tracking-widest mb-4">Client SDKs</p>
      <h2 class="text-2xl lg:text-4xl font-bold text-white mb-4">Build on Any Platform</h2>
      <p class="text-gray-400 max-w-xl mx-auto">Connect to your Colyseus server from any engine, framework, or language. State synchronization works the same everywhere.</p>
    </div>

    <!-- SDK Selector -->
    <div class="flex flex-wrap justify-center gap-2 lg:gap-3 mb-10" id="sdk-selector">
      {sdks.map((sdk, i) => (
        <button
          class={`sdk-btn group flex flex-col items-center justify-between gap-1 px-3 py-3 lg:px-4 lg:py-3 rounded-xl border transition-all cursor-pointer w-[72px] lg:w-[88px] ${i === 0 ? 'active' : ''}`}
          data-sdk={sdk.key}
        >
          <div class="flex items-center justify-center h-7 lg:h-9">
            {sdk.image ? (
              <img src={sdk.image} alt={sdk.name} class="sdk-icon w-7 lg:w-9 transition-all" />
            ) : (
              <span class="sdk-icon w-7 lg:w-9 transition-all" set:html={sdk.svg} />
            )}
          </div>
          <span class="sdk-label text-[10px] lg:text-xs font-medium transition-all whitespace-nowrap">{sdk.name}</span>
          <span class={`text-[9px] font-medium uppercase tracking-wide px-1.5 py-0.5 rounded border ${sdk.tag === 'Alpha' ? 'bg-amber-500/20 text-amber-400 border-amber-500/30' : 'bg-green-500/20 text-green-400 border-green-500/30'}`}>{sdk.tag}</span>
        </button>
      ))}
    </div>

    <!-- SDK Content Panels -->
    <div class="max-w-3xl mx-auto" id="sdk-panels">
      {sdks.map((sdk, i) => (
        <div class={`sdk-panel ${i === 0 ? 'active' : ''}`} data-panel={sdk.key}>
          <SDKClientCode sdk={sdk} />
          <SDKLinks sdk={sdk} />
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* SDK button states */
  .sdk-btn {
    border-color: rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02);
  }
  .sdk-btn:hover {
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
  }
  .sdk-btn.active {
    border-color: rgba(168, 85, 247, 0.5);
    background: rgba(168, 85, 247, 0.1);
  }
  .sdk-btn .sdk-icon {
    opacity: 0.5;
    color: rgb(156, 163, 175);
  }
  .sdk-btn:hover .sdk-icon {
    opacity: 0.8;
  }
  .sdk-btn.active .sdk-icon {
    opacity: 1;
    color: rgb(192, 132, 252);
  }
  .sdk-btn .sdk-label {
    color: rgb(107, 114, 128);
  }
  .sdk-btn:hover .sdk-label {
    color: rgb(156, 163, 175);
  }
  .sdk-btn.active .sdk-label {
    color: rgb(216, 180, 254);
  }

  /* SDK content panels */
  .sdk-panel {
    display: none;
  }
  .sdk-panel.active {
    display: block;
    animation: sdk-fade-in 0.25s ease;
  }
  @keyframes sdk-fade-in {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline>
  (function () {
    var buttons = document.querySelectorAll('#sdk-selector .sdk-btn');
    var panels = document.querySelectorAll('#sdk-panels .sdk-panel');

    if (!buttons.length || !panels.length) return;

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var sdk = btn.dataset.sdk;

        buttons.forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');

        panels.forEach(function (p) { p.classList.remove('active'); });
        var panel = document.querySelector('.sdk-panel[data-panel="' + sdk + '"]');
        if (panel) panel.classList.add('active');
      });
    });
  })();
</script>
