---
import { getCollection } from 'astro:content';
import TestimonialEntry from './TestimonialEntry.astro';

const successStories = (await getCollection('success-stories')).sort(
	(a, b) => new Date(a.data.pubDate) - new Date(b.data.pubDate)
);
---

<section class="border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-20 lg:py-32">
    <p class="text-sm font-medium text-purple-400 uppercase tracking-widest text-center mb-4">Success Stories</p>
    <h2 class="text-2xl lg:text-4xl font-bold text-white text-center mb-12">
      Trusted by Indies and Studios Worldwide
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
      {successStories.filter((story) => story.data.author_img && story.data.quote).map((story) => (
        <TestimonialEntry {...story.data} href={(story.data.published) ? `/success-stories/${story.slug}/` : "/success-stories"} />
      ))}
    </div>

    <div class="text-center">
      <a href="/success-stories" class="group text-sm font-medium text-gray-400 hover:text-white transition-colors">
        View all success stories
        <svg class="inline-block ml-1 transition-transform group-hover:translate-x-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
