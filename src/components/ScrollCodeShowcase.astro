---
import CodeServerRoom from "../content/framework/code-server-room.mdx";
import CodeServerMatchmaking from "../content/framework/code-server-matchmaking.mdx";
import CodeClientJoinRoom from "../content/framework/code-client-join-room.mdx";
import CodeStateServer from "../content/framework/code-statesync-server.mdx";
import CodeStateServerMutate from "../content/framework/code-statesync-mutate-server.mdx";
import CodeStateSyncClient from "../content/framework/code-statesync-client.mdx";
---

<section id="see-it-in-action" class="border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="text-center mb-10">
      <p class="text-sm font-medium text-purple-400 uppercase tracking-widest mb-4">See It In Action</p>
      <h2 class="text-2xl lg:text-4xl font-bold text-white mb-4">From Zero to Multiplayer</h2>
      <p class="text-gray-400 max-w-xl mx-auto">Define rooms, sync state, connect clients. A complete multiplayer server in just a few lines of code.</p>
      <div class="hidden lg:block mt-8">
        <svg class="w-16 h-16 mx-auto text-gray-600 showcase-bounce" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M7 13l5 5 5-5M7 7l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
    </div>

    <!-- Desktop: sticky left + scrolling right -->
    <div class="hidden lg:flex relative gap-16">

      <!-- Left: sticky code panel, vertically centered -->
      <div class="w-1/2">
        <div class="sticky top-0 h-screen flex items-center py-16" id="showcase-code-panel">
          <div class="showcase-panels w-full">
            <div class="showcase-panel active" data-panel="0"><CodeServerRoom /></div>
            <div class="showcase-panel" data-panel="1"><CodeServerMatchmaking /></div>
            <div class="showcase-panel" data-panel="2"><CodeStateServer /></div>
            <div class="showcase-panel" data-panel="3"><CodeStateServerMutate /></div>
            <div class="showcase-panel" data-panel="4"><CodeClientJoinRoom /></div>
            <div class="showcase-panel" data-panel="5"><CodeStateSyncClient /></div>
          </div>
        </div>
      </div>

      <!-- Right: scrollable steps -->
      <div class="w-1/2" id="showcase-steps">
        <div class="h-[40vh]"></div>
        <div class="showcase-step active" data-step="0">
          <span class="showcase-badge badge-server"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 512 512"><path d="M64 32C28.7 32 0 60.7 0 96v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zM64 288c-35.3 0-64 28.7-64 64v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V352c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0z"/></svg>Server-side</span>
          <h3 class="text-2xl font-medium mt-2">Define your room</h3>
          <p class="mt-3 text-gray-400 leading-relaxed">Rooms are the core building block. Each room runs your game logic, handles connections, and manages state. Define lifecycle hooks for when players join, leave, or send messages.</p>
        </div>

        <div class="showcase-step" data-step="1">
          <span class="showcase-badge badge-server"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 512 512"><path d="M64 32C28.7 32 0 60.7 0 96v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zM64 288c-35.3 0-64 28.7-64 64v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V352c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0z"/></svg>Server-side</span>
          <h3 class="text-2xl font-medium mt-2">Expose for matchmaking</h3>
          <p class="mt-3 text-gray-400 leading-relaxed">Register your room type with a single line. Colyseus handles the rest — creating new instances on demand, filling them up, and routing players to the right one.</p>
        </div>

        <div class="showcase-step" data-step="2">
          <span class="showcase-badge badge-server"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 512 512"><path d="M64 32C28.7 32 0 60.7 0 96v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zM64 288c-35.3 0-64 28.7-64 64v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V352c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0z"/></svg>Server-side</span>
          <h3 class="text-2xl font-medium mt-2">Define your state</h3>
          <p class="mt-3 text-gray-400 leading-relaxed">Define game state using decorated schema classes. Colyseus tracks changes and syncs them to all clients with binary delta compression.</p>
        </div>

        <div class="showcase-step" data-step="3">
          <span class="showcase-badge badge-server"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 512 512"><path d="M64 32C28.7 32 0 60.7 0 96v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zM64 288c-35.3 0-64 28.7-64 64v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V352c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0z"/></svg>Server-side</span>
          <h3 class="text-2xl font-medium mt-2">Mutate state</h3>
          <p class="mt-3 text-gray-400 leading-relaxed">Just modify your state objects like regular JavaScript. Colyseus detects changes and broadcasts only the deltas to connected clients.</p>
        </div>

        <div class="showcase-step" data-step="4">
          <span class="showcase-badge badge-client"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 576 512"><path d="M64 0C28.7 0 0 28.7 0 64V352c0 35.3 28.7 64 64 64H240l-10.7 32H160c-17.7 0-32 14.3-32 32s14.3 32 32 32H416c17.7 0 32-14.3 32-32s-14.3-32-32-32H346.7L336 416H512c35.3 0 64-28.7 64-64V64c0-35.3-28.7-64-64-64H64zM512 64V352H64V64H512z"/></svg>Client-side</span>
          <h3 class="text-2xl font-medium mt-2">Connect from the client</h3>
          <p class="mt-3 text-gray-400 leading-relaxed">Connect to your server and join a room with a few lines of code. If no room is available, the server creates one automatically.</p>
        </div>

        <div class="showcase-step" data-step="5">
          <span class="showcase-badge badge-client"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 576 512"><path d="M64 0C28.7 0 0 28.7 0 64V352c0 35.3 28.7 64 64 64H240l-10.7 32H160c-17.7 0-32 14.3-32 32s14.3 32 32 32H416c17.7 0 32-14.3 32-32s-14.3-32-32-32H346.7L336 416H512c35.3 0 64-28.7 64-64V64c0-35.3-28.7-64-64-64H64zM512 64V352H64V64H512z"/></svg>Client-side</span>
          <h3 class="text-2xl font-medium mt-2">Listen to state changes</h3>
          <p class="mt-3 text-gray-400 leading-relaxed">React to state changes with fine-grained callbacks. Know exactly when players join, leave, or any state updates.</p>
        </div>
        <div class="h-[40vh]"></div>
      </div>
    </div>

    <!-- Mobile: stacked layout -->
    <div class="lg:hidden space-y-8">
      <div>
        <span class="showcase-badge badge-server"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 512 512"><path d="M64 32C28.7 32 0 60.7 0 96v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zM64 288c-35.3 0-64 28.7-64 64v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V352c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0z"/></svg>Server-side</span>
        <h3 class="text-xl font-medium mt-2 mb-3">Define your room</h3>
        <p class="text-gray-400 mb-4">Rooms are the core building block. Define lifecycle hooks for when players join, leave, or send messages.</p>
        <CodeServerRoom />
      </div>

      <div>
        <span class="showcase-badge badge-server"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 512 512"><path d="M64 32C28.7 32 0 60.7 0 96v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zM64 288c-35.3 0-64 28.7-64 64v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V352c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0z"/></svg>Server-side</span>
        <h3 class="text-xl font-medium mt-2 mb-3">Expose for matchmaking</h3>
        <p class="text-gray-400 mb-4">Register your room type with a single line. Colyseus handles the rest.</p>
        <CodeServerMatchmaking />
      </div>

      <div>
        <span class="showcase-badge badge-server"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 512 512"><path d="M64 32C28.7 32 0 60.7 0 96v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zM64 288c-35.3 0-64 28.7-64 64v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V352c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0z"/></svg>Server-side</span>
        <h3 class="text-xl font-medium mt-2 mb-3">Define your state</h3>
        <p class="text-gray-400 mb-4">Define game state using decorated schema classes. Colyseus tracks and syncs changes automatically.</p>
        <CodeStateServer />
      </div>

      <div>
        <span class="showcase-badge badge-server"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 512 512"><path d="M64 32C28.7 32 0 60.7 0 96v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zM64 288c-35.3 0-64 28.7-64 64v64c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V352c0-35.3-28.7-64-64-64H64zm280 72a24 24 0 1 1 48 0 24 24 0 1 1 -48 0zm80 0a24 24 0 1 1 48 0 24 24 0 1 1 -48 0z"/></svg>Server-side</span>
        <h3 class="text-xl font-medium mt-2 mb-3">Mutate state</h3>
        <p class="text-gray-400 mb-4">Just modify your state objects. Colyseus detects changes and broadcasts deltas.</p>
        <CodeStateServerMutate />
      </div>

      <div>
        <span class="showcase-badge badge-client"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 576 512"><path d="M64 0C28.7 0 0 28.7 0 64V352c0 35.3 28.7 64 64 64H240l-10.7 32H160c-17.7 0-32 14.3-32 32s14.3 32 32 32H416c17.7 0 32-14.3 32-32s-14.3-32-32-32H346.7L336 416H512c35.3 0 64-28.7 64-64V64c0-35.3-28.7-64-64-64H64zM512 64V352H64V64H512z"/></svg>Client-side</span>
        <h3 class="text-xl font-medium mt-2 mb-3">Connect from the client</h3>
        <p class="text-gray-400 mb-4">Join a room with a few lines of code. If none is available, the server creates one.</p>
        <CodeClientJoinRoom />
      </div>

      <div>
        <span class="showcase-badge badge-client"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 576 512"><path d="M64 0C28.7 0 0 28.7 0 64V352c0 35.3 28.7 64 64 64H240l-10.7 32H160c-17.7 0-32 14.3-32 32s14.3 32 32 32H416c17.7 0 32-14.3 32-32s-14.3-32-32-32H346.7L336 416H512c35.3 0 64-28.7 64-64V64c0-35.3-28.7-64-64-64H64zM512 64V352H64V64H512z"/></svg>Client-side</span>
        <h3 class="text-xl font-medium mt-2 mb-3">Listen to state changes</h3>
        <p class="text-gray-400 mb-4">React to state changes with fine-grained callbacks.</p>
        <CodeStateSyncClient />
      </div>
    </div>
  </div>
</section>

<style>
  /* Code panels - grid stacking for crossfade */
  .showcase-panels {
    display: grid;
    align-items: center;
  }
  .showcase-panel {
    grid-area: 1 / 1;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    pointer-events: none;
    visibility: hidden;
  }
  .showcase-panel.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }

  /* Scroll steps */
  .showcase-step {
    min-height: 40vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    opacity: 0.25;
    transition: opacity 0.4s ease;
  }
  .showcase-step.active {
    opacity: 1;
  }
  .showcase-step:last-child {
    min-height: 30vh;
  }

  /* Step badge */
  .showcase-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    width: fit-content;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }
  .badge-server {
    background: rgba(139, 92, 246, 0.15);
    color: rgb(167, 139, 250);
  }
  .badge-client {
    background: rgba(34, 197, 94, 0.15);
    color: rgb(74, 222, 128);
  }

  @keyframes showcase-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }
  .showcase-bounce {
    animation: showcase-bounce 1.5s ease-in-out infinite;
  }
</style>

<script is:inline>
  (function () {
    var steps = document.querySelectorAll('#showcase-steps .showcase-step');
    var panels = document.querySelectorAll('#showcase-code-panel .showcase-panel');

    if (!steps.length || !panels.length) return;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;

        var idx = entry.target.dataset.step;

        steps.forEach(function (s) { s.classList.remove('active'); });
        entry.target.classList.add('active');

        panels.forEach(function (p) { p.classList.remove('active'); });
        var panel = document.querySelector('.showcase-panel[data-panel="' + idx + '"]');
        if (panel) panel.classList.add('active');
      });
    }, {
      rootMargin: '-48% 0px -48% 0px',
      threshold: 0
    });

    steps.forEach(function (step) { observer.observe(step); });
  })();
</script>
