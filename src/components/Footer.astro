      </div>

      <!-- Products -->
      <div>
        <h3 class="text-white text-sm font-semibold mb-4">Products</h3>
        <ul class="space-y-3 text-sm text-gray-500">
          <li><a href="/cloud-managed-hosting" class="hover:text-gray-300 transition-colors">Colyseus Cloud</a></li>
          <li><a href="/framework" class="hover:text-gray-300 transition-colors">Framework</a></li>
          <li><a href="/pricing" class="hover:text-gray-300 transition-colors">Pricing</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-white text-sm font-semibold mb-4">Resources</h3>
        <ul class="space-y-3 text-sm text-gray-500">
          <li><a href="https://docs.colyseus.io/" class="hover:text-gray-300 transition-colors">Documentation</a></li>
          <li><a href="https://docs.colyseus.io/learn" class="hover:text-gray-300 transition-colors">Learn</a></li>
          <li><a href="/blog" class="hover:text-gray-300 transition-colors">Blog</a></li>
          <li><a href="/success-stories" class="hover:text-gray-300 transition-colors">Success Stories</a></li>
          <li><a href="https://github.com/colyseus/colyseus/releases" class="hover:text-gray-300 transition-colors">Releases</a></li>
        </ul>
      </div>

      <!-- Source Code -->
      <div>
        <h3 class="text-white text-sm font-semibold mb-4">Source Code</h3>
        <ul class="space-y-3 text-sm text-gray-500">
          <li><a href="https://github.com/colyseus/colyseus" class="hover:text-gray-300 transition-colors">Colyseus</a></li>
          <li><a href="https://github.com/colyseus/colyseus.js" class="hover:text-gray-300 transition-colors">JavaScript SDK</a></li>
          <li><a href="https://github.com/colyseus/colyseus-unity-sdk" class="hover:text-gray-300 transition-colors">Unity SDK</a></li>
          <li><a href="https://github.com/colyseus/colyseus-defold" class="hover:text-gray-300 transition-colors">Defold SDK</a></li>
          <li><a href="https://github.com/colyseus/colyseus-construct3" class="hover:text-gray-300 transition-colors">Construct3 SDK</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white text-sm font-semibold mb-4">Company</h3>
        <ul class="space-y-3 text-sm text-gray-500">
          <li><a href="/community" class="hover:text-gray-300 transition-colors">Community</a></li>
          <li><a href="/brand" class="hover:text-gray-300 transition-colors">Brand</a></li>
          <li><a href="https://shop.colyseus.io/" class="hover:text-gray-300 transition-colors">Merch</a></li>
          <li><a href="mailto:support@colyseus.io" class="hover:text-gray-300 transition-colors">Contact</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 pt-8 border-t border-white/5 text-center lg:text-left">
      <p class="text-gray-600 text-sm">&copy; {today.getFullYear()} Endel Dreyer. All rights reserved.</p>
    </div>
  </div>
</footer>
