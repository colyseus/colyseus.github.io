---
const today = new Date();
---

<footer class="border-t border-white/5 mt-20">
  <div class="max-w-7xl mx-auto px-6 pt-16 pb-8">
    <div class="grid grid-cols-2 lg:grid-cols-6 gap-8 lg:gap-12">

      <!-- Brand Column -->
      <div class="col-span-2">
        <a href="/">
          <img src="/images/logos/logo-light.png" alt="Colyseus" class="h-8 mb-4" />
        </a>
        <p class="text-gray-500 text-sm leading-relaxed max-w-xs">
