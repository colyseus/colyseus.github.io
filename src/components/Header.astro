---
interface Props {
  isExpanded?: boolean;
  isBlue?: boolean;
}

const { isExpanded = true, isBlue = false } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
  class={`fixed w-full z-50 transition-all duration-300 border-b
    ${isExpanded
      ? 'bg-[#0a0a0b]/80 backdrop-blur-lg border-white/5'
      : 'border-transparent data-[scrolled=yes]:bg-[#0a0a0b]/80 data-[scrolled=yes]:backdrop-blur-lg data-[scrolled=yes]:border-white/5'
    }`}
  data-scrolled="no"
>
  <nav class="max-w-7xl mx-auto px-6 h-16 lg:h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0">
      <img src="/images/logos/logo-light.png" alt="Colyseus" class="h-7 lg:h-9" />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-1">
      <li>
        <a href="/framework" class={`px-4 py-2 text-sm font-medium transition-colors rounded-lg hover:bg-white/5 ${currentPath === '/framework' ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
          Framework
        </a>
      </li>
      <li>
        <a href="/cloud-managed-hosting" class={`px-4 py-2 text-sm font-medium transition-colors rounded-lg hover:bg-white/5 ${currentPath === '/cloud-managed-hosting' ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
          Cloud
        </a>
      </li>
      <li>
        <a href="/pricing" class={`px-4 py-2 text-sm font-medium transition-colors rounded-lg hover:bg-white/5 ${currentPath === '/pricing' ? 'text-white' : 'text-gray-400 hover:text-white'}`}>
          Pricing
        </a>
      </li>
      <li>
        <a href="https://docs.colyseus.io/" class="px-4 py-2 text-sm font-medium text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-white/5 inline-flex items-center gap-1">
          Docs
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      </li>
    </ul>

    <!-- Desktop Right -->
    <div class="hidden lg:flex items-center gap-2">
      <a href="https://github.com/colyseus" target="_blank" class="p-2 text-gray-500 hover:text-white transition-colors rounded-lg hover:bg-white/5">
        <svg fill="currentColor" width="20" height="20" viewBox="0 0 496 512"><path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3.7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9 1.6 1 3.6.7 4.3-.7.7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3.7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3.7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z"/></svg>
      </a>
      <a href="http://chat.colyseus.io" target="_blank" class="p-2 text-gray-500 hover:text-white transition-colors rounded-lg hover:bg-white/5">
        <svg fill="currentColor" width="20" height="20" viewBox="0 0 16 16"><path d="M13.545 2.907a13.227 13.227 0 0 0-3.257-1.011.05.05 0 0 0-.052.025c-.141.25-.297.577-.406.833a12.19 12.19 0 0 0-3.658 0 8.258 8.258 0 0 0-.412-.833.051.051 0 0 0-.052-.025c-1.125.194-2.22.534-3.257 1.011a.041.041 0 0 0-.021.018C.356 6.024-.213 9.047.066 12.032c.001.014.01.028.021.037a13.276 13.276 0 0 0 3.995 2.02.05.05 0 0 0 .056-.019c.308-.42.582-.863.818-1.329a.05.05 0 0 0-.01-.059.051.051 0 0 0-.018-.011 8.875 8.875 0 0 1-1.248-.595.05.05 0 0 1-.02-.066.051.051 0 0 1 .015-.019c.084-.063.168-.129.248-.195a.05.05 0 0 1 .051-.007c2.619 1.196 5.454 1.196 8.041 0a.052.052 0 0 1 .053.007c.08.066.164.132.248.195a.051.051 0 0 1-.004.085 8.254 8.254 0 0 1-1.249.594.05.05 0 0 0-.03.03.052.052 0 0 0 .003.041c.24.465.515.909.817 1.329a.05.05 0 0 0 .056.019 13.235 13.235 0 0 0 4.001-2.02.049.049 0 0 0 .021-.037c.334-3.451-.559-6.449-2.366-9.106a.034.034 0 0 0-.02-.019Zm-8.198 7.307c-.789 0-1.438-.724-1.438-1.612 0-.889.637-1.613 1.438-1.613.807 0 1.45.73 1.438 1.613 0 .888-.637 1.612-1.438 1.612Zm5.316 0c-.788 0-1.438-.724-1.438-1.612 0-.889.637-1.613 1.438-1.613.807 0 1.451.73 1.438 1.613 0 .888-.631 1.612-1.438 1.612Z"/></svg>
      </a>
      <a
        href="https://cloud.colyseus.io/"
        class={`ml-2 px-4 py-2 rounded-lg text-white text-sm font-medium transition-colors
          ${isBlue
            ? 'bg-blue-600 hover:bg-blue-500'
            : 'bg-purple-600 hover:bg-purple-500'
          }`}
      >
        Deploy on Cloud
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-open" class="lg:hidden p-2 text-gray-400 hover:text-white transition-colors">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
  </nav>
</header>

<!-- Mobile Menu (outside header to avoid backdrop-filter containing block issue) -->
<div id="mobile-menu" class="invisible opacity-0 fixed inset-0 z-50 bg-[#0a0a0b]/95 backdrop-blur-xl lg:hidden transition-[opacity,visibility] duration-300 overflow-y-auto">
  <div class="flex justify-end p-6 sticky top-0 bg-[#0a0a0b]/80 backdrop-blur-xl z-10">
    <button id="mobile-menu-close" class="p-2 text-gray-400 hover:text-white transition-colors">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <nav class="flex flex-col px-8 pb-10 transition-[opacity,transform] duration-300 delay-75 opacity-0 translate-y-2" id="mobile-menu-nav">
    <div class="flex flex-col gap-5 text-lg">
      <a href="/framework" class={`transition-colors ${currentPath === '/framework' ? 'text-white' : 'text-gray-300 hover:text-white'}`}>Framework</a>
      <a href="/cloud-managed-hosting" class={`transition-colors ${currentPath === '/cloud-managed-hosting' ? 'text-white' : 'text-gray-300 hover:text-white'}`}>Cloud</a>
      <a href="/pricing" class={`transition-colors ${currentPath === '/pricing' ? 'text-white' : 'text-gray-300 hover:text-white'}`}>Pricing</a>
      <a href="https://docs.colyseus.io/" class="text-gray-300 hover:text-white transition-colors inline-flex items-center gap-1">
        Docs
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
    </div>

    <a
      href="https://cloud.colyseus.io/"
      class="mt-8 bg-purple-600 hover:bg-purple-500 px-6 py-3 rounded-lg text-white font-medium transition-colors text-center"
    >
      Deploy on Cloud
    </a>

    <div class="mt-10 grid grid-cols-2 gap-8">
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-3">Resources</h3>
        <ul class="space-y-2.5 text-sm text-gray-400">
          <li><a href="/blog" class={`hover:text-white transition-colors ${currentPath === '/blog' ? 'text-white' : ''}`}>Blog</a></li>
          <li><a href="https://docs.colyseus.io/learn" class="hover:text-white transition-colors">Learn</a></li>
          <li><a href="/success-stories" class={`hover:text-white transition-colors ${currentPath === '/success-stories' ? 'text-white' : ''}`}>Success Stories</a></li>
          <li><a href="https://github.com/colyseus/colyseus/releases" class="hover:text-white transition-colors">Releases</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-3">Company</h3>
        <ul class="space-y-2.5 text-sm text-gray-400">
          <li><a href="/community" class={`hover:text-white transition-colors ${currentPath === '/community' ? 'text-white' : ''}`}>Community</a></li>
          <li><a href="/brand" class="hover:text-white transition-colors">Brand</a></li>
          <li><a href="https://shop.colyseus.io/" class="hover:text-white transition-colors">Merch</a></li>
          <li><a href="mailto:support@colyseus.io" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="flex justify-center gap-6 mt-10 pt-8 border-t border-white/5">
      <a href="https://github.com/colyseus" target="_blank" class="text-gray-500 hover:text-white transition-colors">
        <svg fill="currentColor" width="24" height="24" viewBox="0 0 496 512"><path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3.7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3.3 2.9 2.3 3.9 1.6 1 3.6.7 4.3-.7.7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3.7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3.7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z"/></svg>
      </a>
      <a href="http://chat.colyseus.io" target="_blank" class="text-gray-500 hover:text-white transition-colors">
        <svg fill="currentColor" width="24" height="24" viewBox="0 0 16 16"><path d="M13.545 2.907a13.227 13.227 0 0 0-3.257-1.011.05.05 0 0 0-.052.025c-.141.25-.297.577-.406.833a12.19 12.19 0 0 0-3.658 0 8.258 8.258 0 0 0-.412-.833.051.051 0 0 0-.052-.025c-1.125.194-2.22.534-3.257 1.011a.041.041 0 0 0-.021.018C.356 6.024-.213 9.047.066 12.032c.001.014.01.028.021.037a13.276 13.276 0 0 0 3.995 2.02.05.05 0 0 0 .056-.019c.308-.42.582-.863.818-1.329a.05.05 0 0 0-.01-.059.051.051 0 0 0-.018-.011 8.875 8.875 0 0 1-1.248-.595.05.05 0 0 1-.02-.066.051.051 0 0 1 .015-.019c.084-.063.168-.129.248-.195a.05.05 0 0 1 .051-.007c2.619 1.196 5.454 1.196 8.041 0a.052.052 0 0 1 .053.007c.08.066.164.132.248.195a.051.051 0 0 1-.004.085 8.254 8.254 0 0 1-1.249.594.05.05 0 0 0-.03.03.052.052 0 0 0 .003.041c.24.465.515.909.817 1.329a.05.05 0 0 0 .056.019 13.235 13.235 0 0 0 4.001-2.02.049.049 0 0 0 .021-.037c.334-3.451-.559-6.449-2.366-9.106a.034.034 0 0 0-.02-.019Zm-8.198 7.307c-.789 0-1.438-.724-1.438-1.612 0-.889.637-1.613 1.438-1.613.807 0 1.45.73 1.438 1.613 0 .888-.637 1.612-1.438 1.612Zm5.316 0c-.788 0-1.438-.724-1.438-1.612 0-.889.637-1.613 1.438-1.613.807 0 1.451.73 1.438 1.613 0 .888-.631 1.612-1.438 1.612Z"/></svg>
      </a>
    </div>
  </nav>
</div>

{isExpanded
  ? <div class="h-16 lg:h-20"></div>
  : null}

<script is:inline>
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuNav = document.getElementById('mobile-menu-nav');
  const mobileMenuOpen = document.getElementById('mobile-menu-open');
  const mobileMenuClose = document.getElementById('mobile-menu-close');
  if (mobileMenuOpen) mobileMenuOpen.addEventListener('click', () => {
    mobileMenu.classList.remove('invisible', 'opacity-0');
    mobileMenu.classList.add('opacity-100');
    mobileMenuNav.classList.remove('opacity-0', 'translate-y-2');
    mobileMenuNav.classList.add('opacity-100', 'translate-y-0');
  });
  if (mobileMenuClose) mobileMenuClose.addEventListener('click', () => {
    mobileMenu.classList.add('opacity-0');
    mobileMenu.classList.remove('opacity-100');
    mobileMenuNav.classList.add('opacity-0', 'translate-y-2');
    mobileMenuNav.classList.remove('opacity-100', 'translate-y-0');
    mobileMenu.addEventListener('transitionend', () => {
      mobileMenu.classList.add('invisible');
    }, { once: true });
  });

  // Scroll-triggered header background
  const header = document.querySelector('header');
  if (header) {
    const onScroll = () => {
      header.dataset.scrolled = window.scrollY > 50 ? 'yes' : 'no';
    };
    window.addEventListener('scroll', onScroll);
    onScroll();
  }
</script>
