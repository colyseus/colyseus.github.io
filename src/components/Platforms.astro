---
import { Image } from 'astro:assets';
import { sdks } from '../data/sdks';
interface Props {
  align?: 'center' | 'left';
}
const { align = 'center' } = Astro.props;
---
<div class={`flex flex-col ${align === 'left' ? 'items-center lg:items-start' : 'items-center'}`}>
  <p class="text-sm text-gray-500 mb-4 animate-fade-up" style="animation-delay: 0.5s">Supports your favorite engine & platform</p>
  <ul class="flex flex-wrap items-center justify-center gap-4">
    {sdks.filter(sdk => sdk.image).map((sdk, i) => (
      <li class="animate-fade-up" style={`animation-delay: ${0.6 + i * 0.06}s`}>
        <a href={sdk.docsUrl} title={sdk.name} {...sdk.tag === "Alpha" ? { target: "_blank", rel: "noopener noreferrer" } : {}} class="group flex flex-col items-center relative">
          <Image
            src={sdk.image}
            alt={sdk.name}
            class="w-10 lg:w-14 opacity-60 group-hover:opacity-100 group-hover:-translate-y-1 transition-all"
          />
          <span class="absolute top-full mt-1 flex flex-col items-center whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity">
            <span class="text-xs text-gray-500">{sdk.name}</span>
            {sdk.tag === "Alpha" && (
              <span class="text-[10px] font-medium uppercase tracking-wide bg-purple-500/20 text-purple-400 px-1.5 py-0.5 rounded border border-purple-500/30 mt-0.5">{sdk.tag}</span>
            )}
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>
