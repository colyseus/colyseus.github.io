---
interface Props {
  separator?: boolean;
}

const props = Astro.props;
const separator = props.separator;
---
<section>
  <div class={`max-w-7xl mx-auto px-6 text-center flex items-center justify-center lg:flex-row relative py-10 ${(separator) ? "border-b border-white/5" : ""}`}>
    <h1 class="font-display py-2 lg:py-8 text-4xl lg:text-6xl font-bold text-white">
      <slot />
    </h1>
  </div>
</section>
